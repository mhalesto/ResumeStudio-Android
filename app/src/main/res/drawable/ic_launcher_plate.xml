<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Sampled from the iOS tile's corners: it is a diagonal gradient, not a
         flat navy, so a solid fill would read as a different icon beside it. -->
    <gradient
        android:type="linear"
        android:angle="315"
        android:startColor="#283254"
        android:centerColor="#1A2140"
        android:endColor="#0A0D1B" />
</shape>
